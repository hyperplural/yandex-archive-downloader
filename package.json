{
  "name": "yandex-archive-downloader",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && stylelint \"src/**/*.css\"",
